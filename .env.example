# App URLs
NEXT_PUBLIC_APP_URL=https://your-production-domain.com
SHPITTO_APP_BASE_URL=https://your-production-domain.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
CHAT_TASKS_USE_SUPABASE=1

# LLM provider via AIBERM
AIBERM_API_KEY=your-aiberm-api-key
AIBERM_BASE_URL=https://aiberm.com/v1
LLM_MODEL_AIBERM=openai/gpt-5.4-mini
LLM_MODEL_FALLBACK_AIBERM=openai/gpt-5.4

# Prompt Draft web research
SERPER_API_KEY=your-serper-api-key
CHAT_DRAFT_WEB_SEARCH_ENABLED=1

# Cloudflare Pages/D1/R2
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id
R2_BUCKET=your-r2-bucket
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_BASE_URL=https://assets.your-domain.com

# Generated-site contact endpoint
SHPITTO_CONTACT_API_URL=https://your-production-domain.com/api/contact

# Document ingestion
DOCUMENT_INGESTION_ENABLED=1
DOCUMENT_INGESTION_PROVIDER=local
DOCUMENT_INGESTION_MAX_FILE_MB=25
