{
  "name": "industry-v0",
  "private": true,
  "scripts": {
    "build:all": "turbo run build",
    "dev:all": "pnpm --filter web dev:all",
    "dev:all:turbo": "turbo run dev",
    "lint:all": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "prettier": "^3.2.5",
    "turbo": "latest"
  },
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@langchain/core": "^1.1.8",
    "@langchain/langgraph": "^1.0.7",
    "@langchain/openai": "^1.2.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.15.0",
      "follow-redirects": "1.16.0",
      "langsmith": "0.5.19",
      "postcss": "8.5.10",
      "protobufjs": "7.5.5",
      "uuid": "14.0.0"
    }
  },
  "version": "1.0.0",
  "description": "This repository contains the source code for Phase 1 (Industry-v0) of the Shpitto platform.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GiantClam/shpitto.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/GiantClam/shpitto/issues"
  },
  "homepage": "https://github.com/GiantClam/shpitto#readme"
}
