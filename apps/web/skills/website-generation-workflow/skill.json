    "promptAdaptiveDesign": {
      "id": "prompt-adaptive",
      "name": "Prompt-Adaptive",
      "category": "Prompt Derived",
      "reason": "Canonical prompt contains explicit visual requirements; using prompt-adaptive design context instead of a generic template default.",
      "activation": {
        "hexColors": true,
        "minCoreSignals": 3,
        "minCoreSignalsWithExplicitLanguage": 2
      },
      "explicitVisualLanguagePatterns": [
        "visual style",
        "design direction",
        "color",
        "palette",
        "typography",
        "layout",
        "视觉",
        "设计",
        "色调",
        "配色",
        "字体",
        "布局"
      ],
      "signals": [
        { "key": "natural", "pattern": "green|eco|ecological|nature|natural|绿|生态|自然", "core": true, "mood": "natural", "primaryDefault": "naturalPrimary", "accentDefault": "naturalAccent", "surfaceDefault": "naturalSurface" },
        { "key": "warm", "pattern": "warm|approachable|human|friendly|温暖|亲和|友好", "core": true, "mood": "warm", "primaryDefault": "warmPrimary", "accentDefault": "warmAccent" },
        { "key": "accent-warm", "pattern": "orange|amber|橙|暖橙", "core": true, "accentDefault": "warmAccent" },
        { "key": "light", "pattern": "white|light|bright|clean|白色|浅色|明亮|清新", "core": true },
        { "key": "soft", "pattern": "soft|gentle|rounded|柔和|圆润|圆角", "core": true },
        { "key": "professional", "pattern": "professional|institution|authority|trust|standard|专业|机构|标准|可信", "mood": "professional" },
        { "key": "friendly-audience", "pattern": "child|children|kids|family|儿童|适儿|家庭", "core": true, "mood": "friendly" },
        { "key": "editorial", "pattern": "editorial|research|publication|content|reading|研究|资讯|内容|阅读" }
      ],
      "darkModePatterns": ["dark", "black", "midnight", "暗色", "黑色"],
      "defaults": {
        "primary": "#2563EB",
        "naturalPrimary": "#2E8B57",
        "warmPrimary": "#F97316",
        "accent": "#22C55E",
        "naturalAccent": "#8BC34A",
        "warmAccent": "#F59E0B",
        "lightBackground": "#FFFFFF",
        "darkBackground": "#07120E",
        "lightSurface": "#F8FAFC",
        "naturalSurface": "#F5FBF7",
        "darkSurface": "#102019",
        "lightPanel": "#FFFFFF",
        "darkPanel": "#14281F",
        "lightText": "#12312A",
        "darkText": "#F3F8F4",
        "lightMuted": "#51635C",
        "darkMuted": "#B8C8BF",
        "lightBorder": "#D7E7DD",
        "darkBorder": "#274237"
      },
      "typography": "\"Inter\", \"Noto Sans SC\", system-ui, -apple-system, sans-serif",
      "designMd": {
        "title": "Prompt-Adaptive Design System",
        "intro": "This design system is derived from the confirmed Canonical Website Prompt. It overrides generic template aesthetics when the prompt contains explicit visual requirements.",
        "typographyRules": [
          "Use the configured typography stack for readable bilingual content.",
          "Prefer calm professional headings, generous line-height, and no negative letter-spacing."
        ],
        "layoutRules": [
          "Use generous whitespace, clear section rhythm, and source-specific content modules rather than a preset generic shell.",
          "Visual inspiration from external templates is allowed only as structure; prompt-defined colors, mood, audience, and brand semantics remain authoritative."
        ]
      }
    }
  },
  "routePlanningPolicy": {
    "blockedLabels": [
      "and internationalization requirements",
      "and business context",
      "audience",
      "automatically plan first level navigation",
      "auto plan",
      "business context",
      "body",
      "case gallery",
      "case highlights",
      "category tabs",
      "certification row",
      "client proof",
      "comparison strip",
      "contact channels",
      "content modules",
      "content source",
      "content sections",
      "core module entries",
      "conversion goals",
      "cta",
      "design theme",
      "email",
      "faq",
      "featured products",
      "footer",
      "function slots",
      "functional requirements",
      "head",
      "header",
      "hero",
      "infer audience",
      "infer from uploaded materials",
      "language",
      "logo",
      "main",
      "message",
      "name",
      "navigation",
      "pages",
      "page structure",
      "phone",
      "privacy consent",
      "product grid",
      "primary goal",
      "proof",
      "quote form",
      "quote cta",
      "required information",
      "result metrics",
      "second level detail pages",
      "service commitment",
      "site structure",
      "spec cards",
      "target audience",
      "third level content pages",
      "uploaded materials",
      "value strip",
      "website type"
    ],
    "autoPlanningIntentPatterns": [
      "auto(?:matically)?\\s+(?:plan|generate|create)",
      "automatic\\s+(?:planning|sitemap|structure)",
      "multi-page\\s+website\\s*\\(automatically",
      "automatically\\s+plan\\s+first-level\\s+navigation"
    ],
    "defaultAutoRoutes": ["/", "/custom-solutions", "/cases", "/contact", "/about"],
    "conditionalAutoRoutes": [
      {
        "route": "/products",
        "insertBefore": "/custom-solutions",
        "matchPatterns": ["products?", "catalog", "portfolio"]
      },
      {
        "route": "/news",
        "insertBefore": "/contact",
        "matchPatterns": ["news", "blog", "updates"]
      },
      {
        "route": "/downloads",
        "insertBefore": "/contact",
        "matchPatterns": ["download", "whitepaper", "manual", "pdf", "document", "resource"]
      }
    ]
  }
}
