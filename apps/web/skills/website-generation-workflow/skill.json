    "internalLanguage": "english_only",
    "preserveRequestedSiteLocaleAsRequirement": true,
    "avoidCopyingMultilingualRawPromptText": true,
    "avoidCopyingMultilingualRawSourceExcerptsIntoWorkflowFiles": true
  },
