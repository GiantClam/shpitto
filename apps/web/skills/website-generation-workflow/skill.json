    "promptAdaptiveDesign": {
      "id": "prompt-adaptive",
      "name": "Prompt-Adaptive",
      "category": "Prompt Derived",
      "reason": "Canonical prompt contains explicit visual requirements; using prompt-adaptive design context instead of a generic template default.",
      "activation": {
        "hexColors": true,
        "minCoreSignals": 3,
        "minCoreSignalsWithExplicitLanguage": 2
      },
      "explicitVisualLanguagePatterns": [
        "visual style",
        "design direction",
        "color",
        "palette",
        "typography",
        "layout",
        "\u98ce\u683c",
        "\u914d\u8272",
        "\u6392\u7248",
        "\u5c42\u6b21",
        "\u6784\u56fe",
        "\u52a8\u6548"
      ],
      "signals": [
        {
          "key": "natural",
          "pattern": "green|eco|ecological|nature|natural|\u81ea\u7136|\u751f\u6001",
          "core": true,
          "mood": "natural",
          "primaryDefault": "naturalPrimary",
          "accentDefault": "naturalAccent",
          "surfaceDefault": "naturalSurface"
        },
        {
          "key": "warm",
          "pattern": "warm|approachable|human|friendly|\u6e29\u6696|\u4eb2\u548c|\u53cb\u597d",
          "core": true,
          "mood": "warm",
          "primaryDefault": "warmPrimary",
          "accentDefault": "warmAccent"
        },
        {
          "key": "accent-warm",
          "pattern": "orange|amber|\u6a59\u8272|\u7425\u73c0",
          "core": true,
          "accentDefault": "warmAccent"
        },
        {
          "key": "light",
          "pattern": "white|light|bright|clean|\u767d\u8272|\u6d45\u8272|\u660e\u4eae|\u5e72\u51c0",
          "core": true
        },
        {
          "key": "soft",
          "pattern": "soft|gentle|rounded|\u67d4\u548c|\u5706\u89d2|\u8f7b\u67d4",
          "core": true
        },
        {
          "key": "professional",
          "pattern": "professional|institution|authority|trust|standard|\u4e13\u4e1a|\u673a\u6784|\u6743\u5a01|\u53ef\u4fe1",
          "mood": "professional"
        },
        {
          "key": "friendly-audience",
          "pattern": "child|children|kids|family|\u513f\u7ae5|\u5b69\u5b50|\u5bb6\u5ead",
          "core": true,
          "mood": "friendly"
        },
        {
          "key": "editorial",
          "pattern": "editorial|research|publication|content|reading|\u7f16\u8f91|\u7814\u7a76|\u51fa\u7248|\u5185\u5bb9|\u9605\u8bfb"
        }
      ],
      "darkModePatterns": [
        "dark",
        "black",
        "midnight",
        "??",
        "??"
      ],
      "defaults": {
        "primary": "#2563EB",
        "naturalPrimary": "#2E8B57",
        "warmPrimary": "#F97316",
        "accent": "#22C55E",
        "naturalAccent": "#8BC34A",
        "warmAccent": "#F59E0B",
        "lightBackground": "#FFFFFF",
        "darkBackground": "#07120E",
        "lightSurface": "#F8FAFC",
        "naturalSurface": "#F5FBF7",
        "darkSurface": "#102019",
        "lightPanel": "#FFFFFF",
        "darkPanel": "#14281F",
        "lightText": "#12312A",
        "darkText": "#F3F8F4",
        "lightMuted": "#51635C",
        "darkMuted": "#B8C8BF",
        "lightBorder": "#D7E7DD",
        "darkBorder": "#274237"
      },
      "typography": "\"Inter\", \"Noto Sans SC\", system-ui, -apple-system, sans-serif",
      "designMd": {
        "title": "Prompt-Adaptive Design System",
        "intro": "This design system is derived from the confirmed Canonical Website Prompt. It overrides generic template aesthetics when the prompt contains explicit visual requirements.",
        "typographyRules": [
          "Use the configured typography stack for readable bilingual content.",
          "Prefer calm professional headings, generous line-height, and no negative letter-spacing."
        ],
        "layoutRules": [
          "Use generous whitespace, clear section rhythm, and source-specific content modules rather than a preset generic shell.",
          "Visual inspiration from external templates is allowed only as structure; prompt-defined colors, mood, audience, and brand semantics remain authoritative."
        ]
      }
    }
  },
