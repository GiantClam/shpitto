  "refinementPolicy": {
    "defaultMode": "incremental_site_evolution",
    "allowImplicitFullRegenerate": false,
    "subtypes": [
      "patch",
      "structural",
      "route_regenerate"
    ],
    "fullRegenerateTriggers": [
      "full regenerate",
      "regenerate all",
      "rebuild everything",
      "regenerate whole site",
      "rebuild whole site"
    ],
    "structuralRefineTriggers": [
      "complete blog detail pages",
      "complete detail pages",
      "missing detail pages",
      "missing blog content page",
      "add page",
      "remove page"
    ],
    "routeRegenerateTriggers": [
      "rewrite /about",
      "redo blog page",
      "rewrite page",
      "redo page",
      "regenerate page"
    ],
    "rules": [
      "If the user does not explicitly request a whole-site rebuild, keep the task in refinement.",
      "Structural refine may add or remove route files when the current route plan already implies those deliverables or when the user explicitly requests a new page without asking for whole-site regeneration.",
      "Any newly created page must inherit the current site's active theme, shared navigation, and shared footer contract unless the user explicitly requests a shell redesign.",
      "Route regenerate rewrites one route or one route family from the current baseline without discarding the whole site.",
      "Refinement may reopen preview confirmation or Blog confirmation, but it must not auto-deploy."
    ]
  },
  "blogIntegrationPolicy": {
    "route": "/blog",
    "apiEndpoint": "/api/blog/posts",
    "rootAttribute": "data-shpitto-blog-root",
    "listAttribute": "data-shpitto-blog-list",
    "apiAttribute": "data-shpitto-blog-api",
    "detailPathPattern": "/blog/{slug}/",
    "allowImplicitFallbackRoute": false,
    "generationRequiresDetailForAnyBlogRoute": true,
    "previewRequiresStaticOrReadableDetailOutput": true,
    "generationAndDeploymentAreSeparateActions": true,
    "deploymentRequiresExplicitUserAction": true,
    "regenerationRestartsBlogWorkflow": true,
    "regenerationRequiresFreshBlogPreviewConfirmation": true,
    "regenerationReopensDeployHandoff": true,
    "regenerationMustNotEndAtShellPreviewOnly": true,
    "postShellPath": "/shpitto-blog-post-shell.html",
    "themeMetadataPath": "/shpitto-blog-theme.json",
    "generationMode": "site-native-data-source-page",
    "semanticRoutePolicy": {
      "fallbackRoute": "/blog",
      "confidenceThreshold": 70,
      "signals": [
        {
          "patterns": [
            "(?:^|/)blog(?:/|$)",
            "\\bblogs?\\b",
            "articles?"
          ],
          "score": 100,
          "reason": "Explicit blog route or label."
        },
        {
          "patterns": [
            "information[-\\s]?platform",
            "content[-\\s]?stream",
            "article[-\\s]?stream",
            "knowledge[-\\s]?(?:hub|center|base)",
            "insights?",
            "publications?",
            "updates?"
          ],
          "score": 86,
          "reason": "Existing navigation route is a content or information stream."
        },
        {
          "patterns": [
            "news",
            "media",
            "press",
            "stories",
            "journal",
            "magazine",
            "case[-\\s]?library"
          ],
          "score": 78,
          "reason": "Existing navigation route represents dated editorial content."
        },
        {
          "patterns": [
            "research[-\\s]?center",
            "resource[-\\s]?center",
            "resources?",
            "library"
          ],
          "score": 52,
          "reason": "Route may contain content but needs another content-stream signal to own the blog backend."
        }
      ],
      "negativeSignals": [
        {
          "patterns": [
            "download",
            "downloads"
          ],
          "score": 38,
          "reason": "Downloads routes are not automatically editorial blog backends."
        },
        {
          "patterns": [
            "login",
            "register",
            "auth",
            "password"
          ],
          "score": 100,
          "reason": "Auth routes cannot own the blog backend."
        },
        {
          "patterns": [
            "contact",
            "about",
            "home"
          ],
          "score": 30,
          "reason": "Core utility routes should not absorb the blog backend unless explicitly named blog."
        }
      ]
    },
    "presentationPolicy": {
      "backendIsInvisible": true,
      "forbiddenVisibleTermsUnlessExplicitBlogRoute": [
        "Blog data source",
        "blog data-source",
        "Blog backend",
        "Blog API",
        "D1",
        "API mount",
        "content API",
        "article list",
        "runtime",
        "static fallback",
        "fallback card",
        "hydration"
      ],
      "contentModels": [
        {
          "routeSignals": [
            "information platform",
            "knowledge hub",
            "content stream",
            "publication library"
          ],
          "collectionLabels": [
            "case library",
            "standards",
            "reports",
            "policy updates",
            "product database"
          ],
          "cardFields": [
            "type",
            "date",
            "scope",
            "summary",
            "tags",
            "detail link"
          ],
          "detailTone": "resource, report, standard, or case detail page rather than generic blog article"
        },
        {
          "routeSignals": [
            "news",
            "updates",
            "insights"
          ],
          "collectionLabels": [
            "latest updates",
            "feature stories",
            "insight articles",
            "media resources"
          ],
          "cardFields": [
            "section",
            "date",
            "summary",
            "tags",
            "detail link"
          ],
          "detailTone": "editorial news or insight detail page"
        },
        {
          "routeSignals": [
            "blog"
          ],
          "collectionLabels": [
            "articles",
            "topics",
            "tags",
            "archive"
          ],
          "cardFields": [
            "category",
            "date",
            "summary",
            "tags",
            "detail link"
          ],
          "detailTone": "site-native blog article detail page"
        }
      ],
      "rules": [
        "Use the selected route's visible information architecture; blog is the hidden data backend.",
        "Attach the blog data attributes to the page's own list, resource, or database modules without exposing implementation details in visible copy.",
        "When the selected route is not explicitly blog, never title the visible section blog data source, blog backend, or article list.",
        "Fallback cards and dynamic cards should preserve the selected route taxonomy and visual rhythm rather than rendering a detached generic feed."
      ]
    },
    "fallbackCardCount": {
      "min": 3,
      "max": 6
    },
    "contentSeedingPolicy": {
      "deployPublishedPostCount": 3,
      "sourcePriority": [
        "canonicalPrompt",
        "sourceRequirement",
        "uploadedOrExtractedEvidence",
        "userMessages",
        "generatedPageCopy"
      ],
      "rules": [
        "On deploy, create or update 3 published blog records from user-provided content.",
        "Article titles, excerpts, body sections, categories, and tags must be strongly related to the user's provided material and selected content route.",
        "Do not seed generic verification posts, lorem ipsum, template news, or unrelated filler.",
        "Do not delete user-authored blog records when refreshing generated source-derived posts."
      ]
    },
    "rules": [
      "The generated blog page must share the same visual system, language, header, footer, and CTA strategy as the rest of the site.",
      "The blog page must include a stable data-source mount so deployment can bind project-scoped D1 blog data without replacing the page shell.",
      "Deployment derives the dynamic blog detail shell from the generated site so /blog/{slug}/ uses the same language, CSS, navigation, and footer as the generated website.",
      "Generation must write every /blog/{slug}/ detail page from the user's supplied topics, named entities, source materials, and visible card promise so the page expands the intended subject instead of drifting into generic implementation filler.",
      "Fallback article cards are required for preview, no-JS rendering, and SEO-safe first paint.",
      "Static code must not include D1 credentials, Cloudflare binding code, worker source, or secrets.",
      "A regenerate or rebuild request for any site with an explicit blog or selected content-backed route restarts the full blog workflow rather than refreshing only shell pages.",
      "Regeneration must re-emit the blog article preview or confirmation artifact and matching /blog/{slug}/ detail deliverables before deployment is offered again.",
      "Regeneration reopens the deploy handoff stage, but deployment still requires a later explicit user action."
    ]
  }
}
