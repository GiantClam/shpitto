{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:next",
    "dev:all": "concurrently -k -n web,worker \"pnpm dev:next\" \"pnpm worker:chat\"",
    "dev:next": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --turbopack",
    "dev:agent": "npx @langchain/langgraph-cli dev --port 8123 --host 127.0.0.1",
    "worker:chat": "node --experimental-strip-types scripts/chat-task-worker.ts",
    "worker:chat:once": "node --experimental-strip-types scripts/chat-task-worker.ts --once",
    "ops:wa:cleanup": "node --experimental-strip-types scripts/wa-site-cleanup.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/react": "^3.0.160",
    "@industry/db": "workspace:*",
    "@industry/schema": "workspace:*",
    "@langchain/community": "^0.3.15",
    "@langchain/core": "^0.3.15",
    "@langchain/langgraph": "^0.2.45",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/openai": "^0.3.14",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.39.7",
    "@types/canvas-confetti": "^1.9.0",
    "@types/three": "^0.182.0",
    "ai": "^6.0.158",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "0.36.1",
    "framer-motion": "^11.18.2",
    "https-proxy-agent": "^7.0.6",
    "lucide-react": "^0.562.0",
    "mini-svg-data-uri": "^1.4.4",
    "next": "16.1.1",
    "openai": "^6.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "2.6.0",
    "three": "^0.182.0",
    "undici": "^6.21.1",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "tailwindcss": "^4.0.0-alpha.32",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
