{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:next",
    "dev:all": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/dev-all.mts",
    "dev:next": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --turbopack",
    "dev:agent": "npx @langchain/langgraph-cli dev --port 8123 --host 127.0.0.1",
    "worker:chat": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/chat-task-worker.mts",
    "worker:chat:once": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/chat-task-worker.mts --once",
    "railway:start": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/railway-start.mts",
    "deploy-worker": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/deploy-task-worker.mts",
    "deploy-worker:once": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/deploy-task-worker.mts --once",
    "deploy-worker:preflight": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/deploy-worker-preflight.mts",
    "ops:wa:cleanup": "node --experimental-strip-types scripts/wa-site-cleanup.ts",
    "smoke:blog-runtime": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/blog-runtime-smoke.mts",
    "smoke:blog-runtime:wrangler": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/blog-runtime-wrangler-smoke.mts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/react": "^3.0.160",
    "@industry/schema": "workspace:*",
    "@langchain/core": "^0.3.15",
    "@langchain/langgraph": "^0.2.45",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/openai": "^0.3.14",
    "@milkdown/crepe": "^7.20.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.39.7",
    "@types/canvas-confetti": "^1.9.0",
    "@types/three": "^0.182.0",
    "ai": "^6.0.158",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^11.18.2",
    "https-proxy-agent": "^7.0.6",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "mammoth": "^1.12.0",
    "mini-svg-data-uri": "^1.4.4",
    "next": "16.2.4",
    "openai": "^6.15.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "2.6.0",
    "three": "^0.182.0",
    "undici": "^6.24.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.1.17",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "postcss": "^8",
    "tailwindcss": "^4.0.0-alpha.32",
    "typescript": "^5",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
